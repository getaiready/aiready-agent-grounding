{
  "name": "@aiready/agent-grounding",
  "version": "0.14.16",
  "description": "Measures how well an AI agent can navigate a codebase autonomously without human assistance",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "aiready-agent-grounding": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "release": "pnpm build && pnpm publish --no-git-checks",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check . --ignore-path ../../.prettierignore",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "lint:fix": "eslint . --fix",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "aiready",
    "agent-grounding",
    "ai-navigation",
    "code-structure",
    "copilot",
    "claude",
    "chatgpt",
    "ai-assisted-development",
    "autonomous-agents",
    "codebase-navigation"
  ],
  "author": "AIReady Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getaiready/aiready-agent-grounding.git"
  },
  "homepage": "https://github.com/getaiready/aiready-agent-grounding",
  "dependencies": {
    "@aiready/core": "workspace:*",
    "@typescript-eslint/types": "^8.58.0",
    "@typescript-eslint/typescript-estree": "^8.58.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
